(html_cache_config) {
    @html {
        path *.html
    }
    header @html {
        Cache-Control "no-cache, no-store, must-revalidate"
        Pragma "no-cache"
        Expires "0"
    }
}

(reverse_proxy_config) {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
}

https://domain.com {
    import html_cache_config
    encode zstd gzip

    handle /api/* {
        reverse_proxy demo_app_1:8045 {
            import reverse_proxy_config
        }
    }

    handle {
        reverse_proxy demo_app_2:8045 {
            import reverse_proxy_config
        }
    }
}

https://s3.com {
    encode zstd gzip
    @console {
        path /
        path /rustfs/console*
    }
    handle @console {
        reverse_proxy demo_app_3:9001 {
            import reverse_proxy_config
        }
    }
    handle {
        reverse_proxy demo_app_4:9000 {
            import reverse_proxy_config
            request_buffers 0
            response_buffers 0
            header_up X-Amz-Date {header.X-Amz-Date}
            header_up Authorization {header.Authorization}
            transport http {
                read_timeout 300s
                write_timeout 300s
            }
        }
    }
}