{
  "distSpecVersion": "1.1.1",
  "storage": {
    "rootDirectory": "/var/lib/registry",
    "dedupe": true,
    "gc": true
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "auth": {
      "htpasswd": {
        "path": "/etc/zot/htpasswd"
      }
    }
  },
  "log": {
    "level": "info"
  },
  "extensions": {
    "search": {
      "enable": true,
      "cve": {
        "updateInterval": "2h"
      }
    },
    "scrub": {
      "enable": true,
      "interval": "24h"
    }
  },
  "accessControl": {
    "repositories": {
      "**": {
        "defaultPolicy": [],
        "anonymousPolicy": []
      }
    }
  }
}
